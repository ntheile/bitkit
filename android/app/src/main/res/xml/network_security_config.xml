<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext for local development -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
    </domain-config>
    
    <!-- 
    Note: Signal's certificate trust is handled via custom OkHttpClientFactory 
    (SignalCertificateTrust.kt) since network-security-config doesn't affect
    React Native's OkHttp WebSocket connections.
    -->
    
    <!-- Debug builds: also trust user-installed certificates -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="user" />
            <certificates src="system" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
